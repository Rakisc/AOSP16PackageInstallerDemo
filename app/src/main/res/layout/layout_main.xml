<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="安装器Demo"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Pre-approval"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_request_preapproval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请求 Pre-approval" />

            <Button
                android:id="@+id/btn_commit_install"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="提交安装 Session" />
        </LinearLayout>

        <Space
            android:layout_width="6dp"
            android:layout_height="1dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33000000" />

        <Space
            android:layout_width="6dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="应用归档"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_install_archive_seed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="安装归档测试应用" />

            <Button
                android:id="@+id/btn_request_archive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="请求归档 requestArchive" />

            <Button
                android:id="@+id/btn_request_unarchive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="请求解归档 requestUnarchive" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_log_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日志输出区"
            android:textSize="12sp" />
    </ScrollView>

</LinearLayout>
